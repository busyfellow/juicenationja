{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "juicenationja3",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "routes": [
    { "pattern": "juicenationja.com", "custom_domain": true },
    { "pattern": "www.juicenationja.com", "custom_domain": true }
  ]
}
